# Database (Postgres / Supabase connection string)
DATABASE_URL="postgresql://user:password@localhost:5432/dailyhope"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Admin bootstrap (used only by prisma/seed.ts to create the first admin)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-please"

# Cloudinary (optional, for future image uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Site
NEXT_PUBLIC_SITE_NAME="Daily Hope"
